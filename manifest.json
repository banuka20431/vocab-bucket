{
  "manifest_version": 3,
  "name": "Vocab-Bucket",
  "version": "1.0",
  "description": "Lets users save highlighted words on a web page and automatically fetch their meanings",
  "permissions": ["scripting", "activeTab", "webNavigation", "contextMenus", "storage", "downloads"],
  "omnibox": { "keyword" : "vb" },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "commands": {
    "save-to-vocab-bucket": {
      "suggested_key": {
        "default": "Alt+Shift+S"
      },
      "description": "Save selected word"
    }
  },
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"], 
      "js": ["scripts/content.js"]
    }
  ],
  "action": {
    "default_icon": {
      "16": "/images/icons/16.png",
      "32": "/images/icons/32.png",
      "48": "/images/icons/48.png",
      "128": "/images/icons/128.png"
    },
    "default_popup": "popup/main.html"
  },
  "icons": {
    "16": "/images/icons/16.png",
    "32": "/images/icons/32.png",
    "48": "/images/icons/48.png",
    "128": "/images/icons/128.png"
  }
}
